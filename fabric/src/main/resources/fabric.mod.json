{
  "schemaVersion": 1,
  "id": "mobstacker",
  "version": "${version}",
  "name": "MobStacker: Restacked",
  "accessWidener": "mobstacker.accesswidener",
  "description": "Greatly increases performance by stacking mobs together. An actively-developed fork of frikinjay's MobStacker, with region stacking, combat overflow, kill feedback, per-world config and an in-game config GUI.",
  "authors": [
    "michalekjarmark",
    "davidex"
  ],
  "contributors": [
    "frikinjay (original author)"
  ],
  "contact": {
    "homepage": "https://github.com/michalekjarmark/mob-stacker",
    "sources": "https://github.com/michalekjarmark/mob-stacker"
  },
  "license": "LGPL-3.0",
  "icon": "assets/mobstacker/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.frikinjay.mobstacker.fabric.MobStackerFabric"
    ],
    "client": [
      "com.frikinjay.mobstacker.fabric.client.MobStackerClient"
    ]
  },
  "mixins": [
    "mobstacker.mixins.json",
    "mobstacker-fabric.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.11",
    "minecraft": "~1.20.1",
    "java": ">=17",
    "fabric-api": "*"
  },
  "suggests": {
    "letmedespawn": ">=1.4.4"
  }
}
